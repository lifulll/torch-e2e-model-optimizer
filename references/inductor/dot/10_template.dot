  title [label="10 Template and Autotune", shape=box, fillcolor="#233142", fontcolor=white, color="#233142", fontsize=18];
  title -> "AlgorithmSelectorCache" [style=invis];
  "AlgorithmSelectorCache";
  "CUTLASS/CK/CPP Template";
  "ChoiceCaller";
  "ExternKernelChoice";
  "TritonTemplate";
  "TritonTemplateCaller";
  "benchmark";
  "choices list";
